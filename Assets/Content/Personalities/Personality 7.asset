  icon: {fileID: 21300000, guid: d8982a06741d76d4b902159136436d81, type: 3}
  personalityName: "\uC2E0\uC911\uD568"
  description: "\uB2F9\uC2E0\uC740 \uC123\uBD80\uB978 \uD589\uB3D9\uC744 \uACBD\uACC4\uD558\uB294
    \uAC80\uD22C\uC0AC\uC785\uB2C8\uB2E4. \uC989\uC2DC \uB3CC\uACA9\uD558\uAC70\uB098
    \uBB34\uB9AC\uD558\uAC8C \uCD94\uACA9\uD558\uB294 \uBA85\uB839\uBCF4\uB2E4\uB294,
    \uB300\uAE30\xB7\uC9D1\uACB0\xB7\uD638\uC704\xB7\uCE21\uBA74 \uACAC\uC81C\uCC98\uB7FC
    \uC704\uD5D8\uC744 \uAD00\uB9AC\uD558\uB294 \uBA85\uB839\uC744 \uC120\uD638\uD569\uB2C8\uB2E4.
    \uD310\uB2E8\uC774 \uB2A6\uC5B4 \uBCF4\uC77C \uC218\uB294 \uC788\uC5B4\uB3C4,
    \uC4F8\uB370\uC5C6\uB294 \uC8FD\uC74C\uC744 \uC904\uC774\uB294 \uB370\uC5D0\uB294
    \uAC15\uC810\uC774 \uC788\uC2B5\uB2C8\uB2E4. \uB2F9\uC2E0\uC740 \uC6A9\uB9F9\uBCF4\uB2E4
    \uD655\uC2E4\uD568\uC744 \uD0DD\uD569\uB2C8\uB2E4."
  baseLoyalty: 70
