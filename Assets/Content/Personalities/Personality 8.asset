  icon: {fileID: 21300000, guid: d8982a06741d76d4b902159136436d81, type: 3}
  personalityName: "\uAD11\uC2E0\uC801"
  description: "\uB2F9\uC2E0\uC740 \uC77C\uB2E8 \uB9C8\uC74C\uC774 \uAF42\uD788\uBA74
    \uB05D\uAE4C\uC9C0 \uBC00\uC5B4\uBD99\uC774\uB294 \uAC80\uD22C\uC0AC\uC785\uB2C8\uB2E4.
    \uBA85\uB839\uC744 \uBC1B\uC544\uB4E4\uC774\uB294 \uC21C\uAC04 \uC5C4\uCCAD\uB09C
    \uC9D1\uC911\uB825\uC73C\uB85C \uC218\uD589\uD558\uC9C0\uB9CC, \uD55C\uBC88 \uBAB0\uC785\uD558\uBA74
    \uC911\uAC04\uC5D0 \uB2E4\uB978 \uC9C0\uC2DC\uB97C \uBC1B\uC544\uB3C4 \uC27D\uAC8C
    \uBC29\uD5A5\uC744 \uBC14\uAFB8\uC9C0 \uC54A\uC2B5\uB2C8\uB2E4. \uC88B\uC740
    \uB0A0\uC5D4 \uAC00\uC7A5 \uBBFF\uC74C\uC9C1\uD558\uC9C0\uB9CC, \uAF2C\uC774\uBA74
    \uAC00\uC7A5 \uC81C\uC5B4\uD558\uAE30 \uC5B4\uB835\uC2B5\uB2C8\uB2E4. \uB2F9\uC2E0\uC740
    \uBA85\uB839\uC744 \uB4E3\uB294 \uC790\uAC00 \uC544\uB2C8\uB77C, \uBA85\uB839\uC5D0
    \uC0AC\uB85C\uC7A1\uD788\uB294 \uC790\uC785\uB2C8\uB2E4."
  baseLoyalty: 50
